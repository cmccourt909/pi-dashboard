# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in your values
#   cp terraform.tfvars.example terraform.tfvars
#
# NEVER commit terraform.tfvars (it contains secrets)
# ─────────────────────────────────────────────────────────────────────────────

aws_region    = "us-east-1"
instance_type = "t4g.small"    # 2GB RAM, ARM — ~$6/mo

# Your SSH public key (paste the contents of ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA... you@machine"

# Restrict SSH to your IP (find yours at https://whatismyip.com)
ssh_allowed_cidrs = ["203.0.113.42/32"]

# GitHub
github_repo   = "cmccourt909/pi-dashboard"
github_branch = "main"

# Domain (optional — leave empty to access via IP only)
domain_name = ""
admin_email = ""

# App secrets
upload_api_key = "change-me-to-a-random-string"
app_password   = "change-me-to-a-secure-password"
